const PROJECTS = [
  {
    image: "/gales.webp",
    title: "Gales",
    description:
      "Aqui hablo del proyecto Aqui hablo del proyectoAqui hablo del proyectoAqui hablo del proyectoAqui hablo del proyectoAqui hablo del proyectoAqui hablo del proyectoAqui hablo del proyectoAqui hablo del proyectoAqui hablo del proyectoAqui hablo del proyectoAqui hablo del proyectoAqui hablo del proyectoAqui hablo del proyecto",
    link: "https://gales.pe/",
    code: "",
    tags: [
      TAGS.FIGMA,
      TAGS.PNPM,
      TAGS.TURBOPACK,
      TAGS.ASTRO,
      TAGS.HTML,
      TAGS.TAILWIND,
    ],
  },
  {
    image: "/siscog.webp",
    title: "Siscog",
    description:
      "Aqui hablo del proyecto Aqui hablo del proyectoAqui hablo del proyectoAqui hablo del proyectoAqui hablo del proyectoAqui hablo del proyectoAqui hablo del proyectoAqui hablo del proyectoAqui hablo del proyectoAqui hablo del proyectoAqui hablo del proyectoAqui hablo del proyectoAqui hablo del proyectoAqui hablo del proyecto",
    link: "https://siscog.pe/",
    code: "",
    tags: [TAGS.FIGMA, TAGS.WORDPRESS, TAGS.JAVASCRIPT],
  },
  {
    image: "/torresc.webp",
    title: "Siscog",
    description:
      "Aqui hablo del proyecto Aqui hablo del proyectoAqui hablo del proyectoAqui hablo del proyectoAqui hablo del proyectoAqui hablo del proyectoAqui hablo del proyectoAqui hablo del proyectoAqui hablo del proyectoAqui hablo del proyectoAqui hablo del proyectoAqui hablo del proyectoAqui hablo del proyectoAqui hablo del proyecto",
    link: "https://torresc.netlify.app/",
    code: "https://github.com/miguelgallardof/torresc",
    tags: [
      TAGS.FIGMA,
      TAGS.NPM,
      TAGS.WEBPACK,
      TAGS.REACT,
      TAGS.JAVASCRIPT,
      TAGS.CSSMODULES,
      TAGS.BOOSTRAP,
    ],
  },
];
---

<div class="flex flex-col gap-10 justify-center items-center">
  {
    PROJECTS.map(({ image, title, description, tags, link, code }) => (
      <article
        class="max-w-2xl border border-gray-900 rounded-lg shadow dark:bg-gray-800 dark:border-gray-700"
        {...Astro.props}
      >
        <a href="#">
          <img
            loading="lazy"
            class="rounded-t-lg w-100%"
            src={image}
            alt="project image"
          />
        </a>
        <div class="p-5">
          <a href="#">
            <h3 class="mb-2 text-xl font-bold tracking-tight text-purple-900 dark:text-white">
              {title}
            </h3>
          </a>
          <p class="mb-3 font-normal text-gray-500 dark:text-gray-400 text-pretty">
            {description}
          </p>
          <ul class="flex flex-row flex-wrap gap-y-1 pb-6">
            {tags.map((tag) => (
              <span class="flex gap-x-2 items-center font-medium me-2 rounded-lg px-2.5 py-1  text-sm bg-black/20 text-white/80">
                <tag.icon class="size-4" />
                {tag.name}
              </span>
            ))}
          </ul>
          <div class="flex flex-row gap-x-6 items-center justify-end mb-2">
            <a
              href={link}
              data-tooltip-target="tooltip-default"
              target="_blank"
              rel="noopener noreferrer"
            >
              <Link class="size-6 brightness-50 hover:scale-125 hover:brightness-100 transition-colors" />
            </a>
            <div
              id="tooltip-default"
              role="tooltip"
              class="absolute z-10 invisible inline-block px-3 py-2 text-sm font-medium text-white transition-opacity duration-300 bg-gray-900 rounded-lg shadow-sm opacity-0 tooltip dark:bg-gray-700"
            >
              Visitar web
              <div class="tooltip-arrow" data-popper-arrow />
            </div>
            {code && (
              <a href={code} target="_blank" rel="noopener noreferrer">
                <Code class="size-6 brightness-50 hover:scale-125 hover:brightness-100 transition-colors" />
              </a>
            )}
          </div>
        </div>
      </article>
    ))
  }
</div>
