---
import ReactJS from "../icons/ReactJS.astro";
import AstroIcon from "../icons/AstroIcon.astro";
import Bun from "../icons/Bun.astro";
import CSS from "../icons/CSS.astro";
import Bootstrap from "../icons/Bootstrap.astro";
import Code from "../icons/Code.astro";
import Figma from "../icons/Figma.astro";
import HTML5 from "../icons/HTML5.astro";
import JavaScript from "../icons/JavaScript.astro";
import Link from "../icons/Link.astro";
import Npm from "../icons/Npm.astro";
import TailwindCSS from "../icons/TailwindCSS.astro";
import Turbopack from "../icons/Turbopack.astro";
import Vite from "../icons/Vite.astro";
import WordPress from "../icons/WordPress.astro";
import Yarn from "../icons/Yarn.astro";
import Webpack from "../icons/Webpack.astro";
import Pnpm from "../icons/Pnpm.astro";

const TAGS = {
  ASTRO: {
    name: "Astro",
    icon: AstroIcon,
  },
  BOOSTRAP: {
    name: "Bootstrap",
    icon: Bootstrap,
  },
  BUN: {
    name: "Bun",
    icon: Bun,
  },
  CSS: {
    name: "CSS",
    icon: CSS,
  },
  CSSMODULES: {
    name: "CSS Modules",
    icon: CSS,
  },
  FIGMA: {
    name: "Figma",
    icon: Figma,
  },
  HTML: {
    name: "HTML5",
    icon: HTML5,
  },
  JAVASCRIPT: {
    name: "JavaScript",
    icon: JavaScript,
  },
  NPM: {
    name: "Npm",
    icon: Npm,
  },
  PNPM: {
    name: "Pnpm",
    icon: Pnpm,
  },
  REACT: {
    name: "React.js",
    icon: ReactJS,
  },
  TAILWIND: {
    name: "Tailwing",
    icon: TailwindCSS,
  },
  TURBOPACK: {
    name: "Turbopack",
    icon: Turbopack,
  },
  VITE: {
    name: "Vite",
    icon: Vite,
  },
  WEBPACK: {
    name: "Webpack",
    icon: Webpack,
  },
  WORDPRESS: {
    name: "WordPress",
    icon: WordPress,
  },
  YARN: {
    name: "Yarn",
    icon: Yarn,
  },
