---
import Art from "../icons/Art.astro";
import Code from "../icons/Code.astro";
import Game from "../icons/Game.astro";

const EDUCATION = [
  {
    icon: Art,
    title: "Dibujo y pintura | Bellas Artes",
    year: "2016 - 2017",
    description: "Aqui",
  },
  {
    icon: Game,
    title: "Diseño y Desarrollo Multimedia y Videojuegos",
    year: "2016 - 2017",
    description: "Aqui",
  },
  {
    icon: Code,
    title: "Full Stack Developer | Henry",
    year: "2016 - 2017",
    description: "Aqui",
  },
];
---

{
  EDUCATION.map(({ title, year, description }) => (
    <ol class="items-center sm:flex">
      <li class="relative mb-6 sm:mb-0">
        <div class="flex items-center">
          <div class="z-10 flex items-center justify-center w-6 h-6 bg-blue-100 rounded-full ring-0 ring-white dark:bg-blue-900 sm:ring-8 dark:ring-gray-900 shrink-0">
            <svg />
          </div>
        </div>
        <div class="hidden sm:flex w-full bg-gray-200 h-0.5 dark:bg-gray-700" />
      </li>
      <div class="mt-3 sm:pe-8">
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
          {title}
        </h3>
        <time class="block mb-2 text-sm font-normal leading-none text-gray-400 dark:text-gray-500">
          {year}
        </time>
        <p class="text-base font-normal text-gray-500 dark:text-gray-400">
          {description}
        </p>
      </div>
    </ol>
  ))
}
